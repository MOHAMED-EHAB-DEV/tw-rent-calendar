{# Rental Calendar Component — rendered by salla-custom-component #}
{# This file documents the generated HTML structure. The JS component renders this dynamically. #}

<div class="rental-calendar-container">
  <h3 class="calendar-title"></h3>

  <div class="rental-calendar">
    <div class="calendar-header">
      <span class="current-month"></span>
      <div class="nav-buttons">
        <button type="button" class="prev-month" aria-label="Previous Month">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button type="button" class="next-month" aria-label="Next Month">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="calendar-grid"></div>
  </div>

  <div class="calendar-error-msg hidden" id="calendar-error-msg"></div>

  <div class="calendar-footer" hidden>
    <div class="duration-info">
      <span class="duration-label"></span>: <span class="days-count">0</span> <span class="days-label"></span>
    </div>
    <div class="hint-info">
      <span class="calendar-hint"></span>
    </div>
  </div>
</div>
